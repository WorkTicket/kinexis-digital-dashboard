# Kinexis Backend Environment Variables
# Copy this file to .env and fill in your values

# Encryption key for stored credentials.
# Desktop: Electron generates a per-install key in userData (do not bake one shared key into the installer).
# Dev without Electron: generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or leave empty — backend will create backend/.kinexis_fernet_key on first run.
FERNET_KEY=

# Google account sign-in (one-time Kinexis build setup — end users just click Sign in with Google)
# Option A: set values below
# Option B: copy oauth.json.example to oauth.json (preferred for packaged builds)
# Google Cloud Console → OAuth client → redirect: http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare account sign-in (one-time Kinexis build setup — end users just click Sign in with Cloudflare)
# Cloudflare Dashboard → Manage Account → OAuth clients → public desktop app with PKCE
# Redirect URI: http://127.0.0.1:8000/auth/cloudflare/callback
# Only client_id is required for end-user sign-in. client_secret is optional.
CLOUDFLARE_CLIENT_ID=
CLOUDFLARE_CLIENT_SECRET=

# Optional legacy fallback
CLOUDFLARE_API_TOKEN=

# AI provider: ollama (default) | anthropic
AI_PROVIDER=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Best for ~12GB VRAM (RTX 5070): qwen3:14b — strong JSON / playbooks
# Marketing-tuned (recommended): create with
#   ollama create kinexis-marketing -f kinexis/backend/ollama/Modelfile
# then set OLLAMA_MODEL=kinexis-marketing
# Weight-tuned (after QLoRA + merge + GGUF):
#   powershell -File kinexis/backend/finetune/run_all.ps1
# then set OLLAMA_MODEL=kinexis-marketing-ft
# Prompt-tuned 14B (recommended for playbooks / JSON):
#   ollama create kinexis-marketing -f kinexis/backend/ollama/Modelfile
# Weight-tuned 8B is faster but often returns unusable playbook JSON — keep as fallback only.
OLLAMA_MODEL=kinexis-marketing
OLLAMA_FALLBACK_MODEL=qwen3:14b
# Context window for richer prompts (top queries/pages + insights). Cap at 16384 in code.
OLLAMA_NUM_CTX=16384
# Lower = more factual/consistent; 0.3–0.45 recommended for playbooks
OLLAMA_TEMPERATURE=0.35
# Seconds — local 14B plans can take 2–4 minutes with large context
OLLAMA_TIMEOUT=300

# Backend config
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# SQLite by default; Electron overrides with userData path
DATABASE_URL=
# Disable OpenAPI docs in packaged builds: 1|true|yes
KINEAXIS_DISABLE_DOCS=
# Client portal (remote share links). Prefer Settings → Client portal in the app.
# When enabled via Electron, sets ALLOW_REMOTE=1, binds 0.0.0.0, disables docs.
KINEAXIS_PORTAL_MODE=
# Public HTTPS base for share links (Cloudflare Tunnel / ngrok). No trailing slash.
PUBLIC_BASE_URL=
# Allow non-loopback clients (set automatically in portal mode)
KINEAXIS_ALLOW_REMOTE=

# Local desktop API auth (Electron sets this automatically; optional for bare uvicorn)
# Generate once or leave empty — backend will create backend/.kinexis_api_token
KINEAXIS_API_TOKEN=
# Require X-Kinexis-Token / Bearer on API routes (set 0 only for local tests)
KINEAXIS_REQUIRE_API_TOKEN=1
# For Next.js `next dev` without Electron, put the same token in frontend/.env.local:
#   NEXT_PUBLIC_KINEAXIS_API_TOKEN=<same value as KINEAXIS_API_TOKEN>

# Live page HTML for AI plans/briefs (static fetch; no JS render by default)
PAGE_CONTENT_USER_AGENT=KinexisAuditBot/1.0 (+https://kinexisdigital.com/bot)
PAGE_CONTENT_CACHE_HOURS=24
PAGE_CONTENT_RENDER_JS=false

# Licensed SERP API — leave SERP_PROVIDER empty to disable (recommended until needed)
# Options: serpapi | dataforseo | google_cse
SERP_PROVIDER=
SERP_API_KEY=
# Required only for google_cse:
SERP_GOOGLE_CSE_ID=
SERP_MAX_QUERIES_PER_SYNC=10
SERP_CACHE_HOURS=72

# Google Ads API — developer token (also settable in Settings or per-datasource)
GOOGLE_ADS_DEVELOPER_TOKEN=
